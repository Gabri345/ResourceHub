@page
@model ResourceHub.Pages.Resources.FavoritesModel

@{
    ViewData["Title"] = "My favorites";
}

<div class="page-heading">
    <div>
        <p class="text-uppercase text-muted small mb-1">Profile</p>
        <h1>My favorites</h1>
        <p class="text-muted mb-0">Resources you saved for later.</p>
    </div>
    <a asp-page="./Index" class="btn btn-outline-secondary">Browse resources</a>
</div>

@if (!Model.Resources.Any())
{
    <div class="empty-state">
        <h2>No favorites yet</h2>
        <p>Save resources from the library and they will appear here.</p>
        <a asp-page="./Index" class="btn btn-primary">Find resources</a>
    </div>
}
else
{
    <div class="resource-grid">
        @foreach (var item in Model.Resources)
        {
            var averageRating = item.Ratings.Any() ? item.Ratings.Average(r => r.Value).ToString("0.0") : "No rating";

            <article class="resource-card">
                <div class="d-flex justify-content-between gap-3">
                    <span class="badge text-bg-light">@item.Category</span>
                    @if (item.Reports.Any(r => !r.IsResolved))
                    {
                        <span class="badge text-bg-warning">Reported</span>
                    }
                </div>
                <h2>@item.Title</h2>
                <p>@item.Description</p>
                <div class="resource-meta">
                    <span>@item.UploadDate.ToString("dd.MM.yyyy")</span>
                    <span>Rating: @averageRating</span>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Open</a>
                    <form method="post" asp-page-handler="Remove" asp-route-id="@item.Id">
                        <button type="submit" class="btn btn-sm btn-warning">Saved</button>
                    </form>
                    @if (!string.IsNullOrWhiteSpace(item.FilePath))
                    {
                        <a href="@item.FilePath" class="btn btn-sm btn-outline-secondary" target="_blank">File</a>
                    }
                </div>
            </article>
        }
    </div>
}
