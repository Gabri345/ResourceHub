@page
@model ResourceHub.Pages.Resources.CreateModel

@{
    ViewData["Title"] = "Upload resource";
}

<div class="page-heading">
    <div>
        <p class="text-uppercase text-muted small mb-1">ResourceHub</p>
        <h1>Upload a resource</h1>
        <p class="text-muted mb-0">Add plans, images, informatics files, homework examples or other useful study material.</p>
    </div>
</div>

<form method="post" enctype="multipart/form-data" class="resource-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Resource.Title" class="form-label"></label>
        <input asp-for="Resource.Title" class="form-control" placeholder="Example: C# arrays exercise plan" />
        <span asp-validation-for="Resource.Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Resource.Category" class="form-label"></label>
        <select asp-for="Resource.Category" class="form-select">
            <option value="">Choose category</option>
            <option>Informatics</option>
            <option>Plans</option>
            <option>Images</option>
            <option>Presentations</option>
            <option>Homework</option>
            <option>Projects</option>
            <option>Other</option>
        </select>
        <span asp-validation-for="Resource.Category" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Resource.Description" class="form-label"></label>
        <textarea asp-for="Resource.Description" class="form-control" rows="5" placeholder="Describe what the resource contains and when it is useful."></textarea>
        <span asp-validation-for="Resource.Description" class="text-danger"></span>
    </div>

    <div class="mb-4">
        <label asp-for="UploadFile" class="form-label">File or image</label>
        <input asp-for="UploadFile" class="form-control" type="file" />
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Publish resource</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
