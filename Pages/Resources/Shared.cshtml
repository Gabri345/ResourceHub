@page
@model ResourceHub.Pages.Resources.SharedModel

@{
    ViewData["Title"] = "Shared with me";
}

<div class="page-heading">
    <div>
        <p class="text-uppercase text-muted font-monospace small mb-1 fw-bold" style="letter-spacing: 0.5px;">Private library</p>
        <h1>Private & Shared</h1>
        <p class="text-muted mb-0">Your private uploads and resources shared with you — organized by folder.</p>
    </div>
    <a asp-page="./Index" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Browse library
    </a>
</div>

@if (!Model.ResourcesByFolder.Any())
{
    <div class="empty-state">
        <div class="mb-3 text-muted">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2z"></path></svg>
        </div>
        <h2>No private resources yet</h2>
        <p>Upload a private resource or ask someone to share one with you — it will appear here organized by folder.</p>
        <a asp-page="./Index" class="btn btn-primary">Explore public resources</a>
    </div>
}
else
{
    @foreach (var folder in Model.ResourcesByFolder)
    {
        <div class="shared-folder mb-5">
            <div class="shared-folder__header">
                <div class="shared-folder__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2z"></path></svg>
                </div>
                <div>
                    <h2 class="shared-folder__name">@folder.Key</h2>
                    <span class="shared-folder__count">@folder.Value.Count resource@(folder.Value.Count != 1 ? "s" : "")</span>
                </div>
            </div>

            <div class="resource-grid">
                @foreach (var item in folder.Value)
                {
                    var averageRating = item.Ratings.Any() ? item.Ratings.Average(r => r.Value).ToString("0.0") : "No rating";
                    var isOwner = item.UploaderId == User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);

                    <article class="resource-card resource-card--private">
                        <div class="d-flex justify-content-between align-items-center gap-3">
                            <span class="badge text-bg-light">@item.Category</span>
                            @if (isOwner)
                            {
                                <span class="badge private-badge">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                    Private
                                </span>
                            }
                            else
                            {
                                <span class="badge shared-badge">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
                                    Shared
                                </span>
                            }
                        </div>
                        <h2>@item.Title</h2>
                        <p>@item.Description</p>
                        <div class="resource-meta">
                            <span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                @item.UploadDate.ToString("dd.MM.yyyy")
                            </span>
                            <span class="d-flex align-items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-warning me-1"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                @averageRating
                            </span>
                        </div>
                        <div class="d-flex align-items-center gap-2 mt-4 pt-2">
                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary flex-grow-1">Open</a>
                            @if (!string.IsNullOrWhiteSpace(item.FilePath))
                            {
                                <a asp-page="./Details" asp-page-handler="Download" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center" style="width:38px;height:38px;padding:0;" title="Download file">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        </div>
    }
}
