@page "{id:int}"
@model ResourceHub.Pages.Resources.DetailsModel

@{
    ViewData["Title"] = Model.Resource.Title;
}

<div class="page-heading">
    <div>
        <p class="text-uppercase text-muted small mb-1">@Model.Resource.Category</p>
        <h1>@Model.Resource.Title</h1>
        <p class="text-muted mb-0">Uploaded on @Model.Resource.UploadDate.ToString("dd.MM.yyyy HH:mm")</p>
    </div>
    <div class="d-flex gap-2">
        @if (Model.CanDeleteResource)
        {
            <a asp-page="./Delete" asp-route-id="@Model.Resource.Id" class="btn btn-outline-danger">Delete</a>
        }
        <form method="post" asp-page-handler="ToggleFavorite" asp-route-id="@Model.Resource.Id">
            <button type="submit" class="btn @(Model.IsFavorite ? "btn-warning" : "btn-outline-primary")">
                @(Model.IsFavorite ? "Saved" : "Save")
            </button>
        </form>
        <a asp-page="./Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<section class="resource-detail">
    <div>
        <h2>Description</h2>
        <p>@Model.Resource.Description</p>

        @if (!string.IsNullOrWhiteSpace(Model.Resource.FilePath))
        {
            <div class="file-preview">
                <div class="file-preview__header">
                    <div>
                        <h2>File preview</h2>
                        <p class="text-muted mb-0">@Model.Resource.FileName</p>
                    </div>
                    <a href="@Model.Resource.FilePath" target="_blank" class="btn btn-outline-primary">Open in new tab</a>
                </div>

                @switch (Model.PreviewKind)
                {
                    case "image":
                        <img src="@Model.Resource.FilePath" alt="@Model.Resource.Title" class="file-preview__image" />
                        break;
                    case "pdf":
                        <iframe src="@Model.Resource.FilePath" title="@Model.Resource.Title" class="file-preview__frame"></iframe>
                        break;
                    case "text":
                        <pre class="file-preview__text"><code>@Model.PreviewText</code></pre>
                        break;
                    case "unsupported":
                        <div class="file-preview__empty">
                            <h3>Preview is not available for this file type</h3>
                            <p>Use the button above to open the file. Some document formats, like Word or PowerPoint, cannot be previewed directly by the browser.</p>
                        </div>
                        break;
                    default:
                        <div class="file-preview__empty">
                            <h3>No file preview</h3>
                            <p>This resource does not have a file attached.</p>
                        </div>
                        break;
                }
            </div>
        }
    </div>

    <aside>
        <div class="stat-box">
            <span>Average rating</span>
            <strong>@(Model.AverageRating.HasValue ? Model.AverageRating.Value.ToString("0.0") : "No rating")</strong>
        </div>
        <div class="stat-box">
            <span>Comments</span>
            <strong>@Model.Resource.Comments.Count</strong>
        </div>
        <div class="stat-box">
            <span>Open reports</span>
            <strong>@Model.Resource.Reports.Count(r => !r.IsResolved)</strong>
        </div>
    </aside>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<section class="interaction-grid">
    <form method="post" asp-page-handler="Rating" asp-route-id="@Model.Resource.Id" class="interaction-panel">
        <h2>@(Model.CurrentUserRating is null ? "Rate this resource" : "Update your rating")</h2>
        <select asp-for="RatingValue" class="form-select">
            <option value="5">5 - Excellent</option>
            <option value="4">4 - Useful</option>
            <option value="3">3 - Okay</option>
            <option value="2">2 - Needs work</option>
            <option value="1">1 - Not useful</option>
        </select>
        <button type="submit" class="btn btn-primary mt-3">@(Model.CurrentUserRating is null ? "Submit rating" : "Update rating")</button>
        @if (!User.Identity?.IsAuthenticated ?? true)
        {
            <p class="text-muted mt-2 mb-0">Login is required to rate.</p>
        }
    </form>

    <form method="post" asp-page-handler="Report" asp-route-id="@Model.Resource.Id" class="interaction-panel">
        <h2>Report false information</h2>
        @if (Model.CurrentUserHasReported)
        {
            <p class="text-muted mb-0">You have already reported this resource.</p>
        }
        else
        {
            <textarea asp-for="ReportReason" class="form-control" rows="4" placeholder="Explain what is wrong or misleading."></textarea>
            <button type="submit" class="btn btn-outline-danger mt-3">Send report</button>
            @if (!User.Identity?.IsAuthenticated ?? true)
            {
                <p class="text-muted mt-2 mb-0">Login is required to report.</p>
            }
        }
    </form>
</section>

<section class="comments-section">
    <h2>Comments</h2>

    <form method="post" asp-page-handler="Comment" asp-route-id="@Model.Resource.Id" class="mb-4">
        <textarea asp-for="NewComment" class="form-control" rows="3" placeholder="Add a helpful comment or correction."></textarea>
        <button type="submit" class="btn btn-primary mt-3">Comment</button>
    </form>

    @if (!Model.Resource.Comments.Any())
    {
        <p class="text-muted">No comments yet.</p>
    }
    else
    {
        foreach (var comment in Model.Resource.Comments)
        {
            <article class="comment-item">
                <p>@comment.Content</p>
                <span>@comment.CreatedOn.ToString("dd.MM.yyyy HH:mm")</span>
            </article>
        }
    }
</section>
