@page
@model ResourceHub.Pages.Resources.IndexModel

@{
    ViewData["Title"] = "Resources";
}

<div class="page-heading">
    <div>
        <p class="text-uppercase text-muted font-monospace small mb-1 fw-bold" style="letter-spacing: 0.5px;">Shared library</p>
        <h1>Resources</h1>
        <p class="text-muted mb-0">Browse learning resources by school subject, rating, and upload date.</p>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-page="Create" class="btn btn-primary d-inline-flex align-items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Upload
        </a>
    }
    else
    {
        <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Resources/Create" class="btn btn-primary">Login to upload</a>
    }
</div>

<form method="get" class="resource-toolbar">
    <input name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by title, description or subject..." />
    <select name="category" class="form-select">
        <option value="">All subjects</option>
        @foreach (var category in Model.Categories)
        {
            <option value="@category" selected="@(Model.Category == category)">@category</option>
        }
    </select>
    <button type="submit" class="btn btn-primary px-4">Search</button>
</form>

@if (!Model.Resource.Any())
{
    <div class="empty-state">
        <div class="mb-3 text-muted">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="15" x2="15" y2="15"></line></svg>
        </div>
        <h2>No resources yet</h2>
        <p>Be the first to upload something useful for the community.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-page="Create" class="btn btn-primary">Upload resource</a>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Resources/Create" class="btn btn-primary">Login to upload</a>
        }
    </div>
}
else
{
    <div class="resource-grid">
        @foreach (var item in Model.Resource)
        {
            var averageRating = item.Ratings.Any() ? item.Ratings.Average(r => r.Value).ToString("0.0") : "No rating";
            var isFavorite = Model.FavoriteResourceIds.Contains(item.Id);

            <article class="resource-card">
                <div class="d-flex justify-content-between align-items-center gap-3">
                    <span class="badge text-bg-light">@item.Category</span>
                    @if (item.Reports.Any(r => !r.IsResolved))
                    {
                        <span class="badge text-bg-warning">Reported</span>
                    }
                </div>
                <h2>@item.Title</h2>
                <p>@item.Description</p>
                <div class="resource-meta">
                    <span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        @item.UploadDate.ToString("dd.MM.yyyy")
                    </span>
                    <span class="d-flex align-items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-warning me-1"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        @averageRating
                    </span>
                </div>
                <div class="d-flex align-items-center gap-2 mt-4 pt-2">
                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary flex-grow-1">Open</a>
                    
                    <form method="post" asp-page-handler="ToggleFavorite" asp-route-id="@item.Id" asp-route-searchTerm="@Model.SearchTerm" asp-route-category="@Model.Category" class="m-0">
                        <button type="submit" class="btn btn-sm @(isFavorite ? "btn-warning" : "btn-outline-secondary") d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; padding: 0;">
                            @if (isFavorite)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z"/></svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
                            }
                        </button>
                    </form>
                    
                    @if (!string.IsNullOrWhiteSpace(item.FilePath))
                    {
                        <a href="@item.FilePath" class="btn btn-sm btn-outline-secondary d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; padding: 0;" target="_blank" title="View attached file">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
                        </a>
                    }
                </div>
            </article>
        }
    </div>
}

