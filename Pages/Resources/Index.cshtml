@page
@model ResourceHub.Pages.Resources.IndexModel

@{
    ViewData["Title"] = "Resources";
}

<div class="page-heading">
    <div>
        <p class="text-uppercase text-muted small mb-1">Shared library</p>
        <h1>Resources</h1>
        <p class="text-muted mb-0">Browse plans, informatics files, images and project material shared by the community.</p>
    </div>
    <a asp-page="Create" class="btn btn-primary">Upload</a>
</div>

<form method="get" class="resource-toolbar">
    <input name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by title, description or category" />
    <select name="category" class="form-select">
        <option value="">All categories</option>
        @foreach (var category in new[] { "Informatics", "Plans", "Images", "Presentations", "Homework", "Projects", "Other" })
        {
            <option value="@category" selected="@(Model.Category == category)">@category</option>
        }
    </select>
    <button type="submit" class="btn btn-outline-primary">Search</button>
</form>

@if (!Model.Resource.Any())
{
    <div class="empty-state">
        <h2>No resources yet</h2>
        <p>Be the first to upload something useful.</p>
        <a asp-page="Create" class="btn btn-primary">Upload resource</a>
    </div>
}
else
{
    <div class="resource-grid">
        @foreach (var item in Model.Resource)
        {
            var averageRating = item.Ratings.Any() ? item.Ratings.Average(r => r.Value).ToString("0.0") : "No rating";
            var extension = System.IO.Path.GetExtension(item.FileName).ToLowerInvariant();
            var isImage = extension is ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".bmp";

            <article class="resource-card">
                <div class="d-flex justify-content-between gap-3">
                    <span class="badge text-bg-light">@item.Category</span>
                    @if (item.Reports.Any(r => !r.IsResolved))
                    {
                        <span class="badge text-bg-warning">Reported</span>
                    }
                </div>
                <h2>@item.Title</h2>
                <p>@item.Description</p>
                @if (!string.IsNullOrWhiteSpace(item.FilePath))
                {
                    <div class="resource-file">
                        @if (isImage)
                        {
                            <img src="@item.FilePath" alt="@item.Title" class="resource-file__thumb" />
                        }
                        else
                        {
                            <div class="resource-file__icon">@extension.TrimStart('.').ToUpperInvariant()</div>
                        }
                        <div>
                            <strong>@item.FileName</strong>
                            <span>Attached file</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="resource-file resource-file--missing">
                        <div class="resource-file__icon">?</div>
                        <div>
                            <strong>No file attached</strong>
                            <span>This resource has no saved file path.</span>
                        </div>
                    </div>
                }
                <div class="resource-meta">
                    <span>@item.UploadDate.ToString("dd.MM.yyyy")</span>
                    <span>Rating: @averageRating</span>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Open</a>
                    @if (!string.IsNullOrWhiteSpace(item.FilePath))
                    {
                        <a href="@item.FilePath" class="btn btn-sm btn-outline-secondary" target="_blank">View file</a>
                    }
                </div>
            </article>
        }
    </div>
}
