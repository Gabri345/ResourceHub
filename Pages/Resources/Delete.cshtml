@page "{id:int}"
@model ResourceHub.Pages.Resources.DeleteModel

@{
    ViewData["Title"] = "Delete resource";
}

<div class="page-heading">
    <div>
        <p class="text-uppercase text-muted small mb-1">Delete resource</p>
        <h1>@Model.Resource.Title</h1>
        <p class="text-muted mb-0">This action removes the resource, its comments, ratings, reports and uploaded file.</p>
    </div>
    <a asp-page="./Details" asp-route-id="@Model.Resource.Id" class="btn btn-outline-secondary">Cancel</a>
</div>

<section class="resource-form">
    <h2>Are you sure?</h2>
    <p>@Model.Resource.Description</p>

    <dl class="row">
        <dt class="col-sm-3">Category</dt>
        <dd class="col-sm-9">@Model.Resource.Category</dd>

        <dt class="col-sm-3">Uploaded on</dt>
        <dd class="col-sm-9">@Model.Resource.UploadDate.ToString("dd.MM.yyyy HH:mm")</dd>

        @if (!string.IsNullOrWhiteSpace(Model.Resource.FileName))
        {
            <dt class="col-sm-3">File</dt>
            <dd class="col-sm-9">@Model.Resource.FileName</dd>
        }
    </dl>

    <form method="post" asp-route-id="@Model.Resource.Id" class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Delete resource</button>
        <a asp-page="./Details" asp-route-id="@Model.Resource.Id" class="btn btn-outline-secondary">Keep resource</a>
    </form>
</section>
